   "source": [
    "# v1 — Keşifsel Veri Analizi (EDA)\n",
    "\n",
    "**Veri kaynağı:** `/home/feb/Documents/omsiingereklidosyalar/`  \n",
    "**Amaç:** Yeni 360-SKU veri setini anlamak, veri kalitesi sorunlarını tespit etmek, model kararlarını bilgilendirmek.  \n",
    "**Sonraki adım:** `v1_processing.ipynb` — temizlik ve panel yeniden üretimi."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.ticker as mticker\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "DATA_DIR = '/home/feb/Documents/omsiingereklidosyalar/'\n",
    "\n",
    "panel  = pd.read_csv(DATA_DIR + 'panel_sales_orders_stock.csv', parse_dates=['ds'])\n",
    "cfg    = pd.read_csv(DATA_DIR + 'sku_config.csv')\n",
    "attr   = pd.read_csv(DATA_DIR + 'sku_attributes.csv')\n",
    "\n",
    "panel = panel.merge(attr[['sku','ItAttrDesc']], on='sku', how='left')\n",
    "\n",
    "print(f'Panel: {len(panel):,} satır | {panel[\"sku\"].nunique()} SKU | {panel[\"ds\"].min().date()} → {panel[\"ds\"].max().date()}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Genel Bakış"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('=== KATEGORİ DAĞILIMI ===')\n",
    "print(attr['ItAttrDesc'].value_counts().to_string())\n",
    "print()\n",
    "print('=== FEATURE KULLANILABİLİRLİK (ham panel) ===')\n",
    "for col in ['y', 'orders', 'stock']:\n",
    "    nonzero = (panel[col] != 0).mean()\n",
    "    neg     = (panel[col] < 0).mean()\n",
    "    print(f'  {col}: dolu={nonzero:.1%}  negatif={neg:.1%}')\n",
    "\n",
    "print()\n",
    "print('⚠️  UYARI: orders ve stock neredeyse tamamen sıfır!')\n",
    "print('   Neden: combineFİles.py tarih parsing bug (dayfirst eksik)')\n",
    "print('   Çözüm: v1_processing.ipynb'"'"'de düzeltilecek')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. SKU Tip Sınıflandırması"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def classify_sku(y_series):\n",
    "    y = y_series.values\n",
    "    zero_pct = (y == 0).mean()\n",
    "    nz = y[y > 0]\n",
    "    mean_nz = nz.mean() if len(nz) else 0\n",
    "    cv = nz.std() / mean_nz if mean_nz > 0 else 0\n",
    "    if zero_pct >= 0.70:   return 'ÖLMEKTE'\n",
    "    if zero_pct >= 0.40:   return 'SEYREK'\n",
    "    if cv > 1.0:           return 'LUMPY'\n",
    "    if mean_nz < 50:       return 'DÜŞÜK HACİM'\n",
    "    return 'NORMAL'\n",
    "\n",
    "sku_stats = []\n",
    "for sku, grp in panel.groupby('sku'):\n",
    "    y = grp['y']\n",
    "    nz = y[y > 0]\n",
    "    sku_stats.append({\n",
    "        'sku':      sku,\n",
    "        'cat':      grp['ItAttrDesc'].iloc[0],\n",
    "        'zero_pct': (y == 0).mean(),\n",
    "        'mean':     y.mean(),\n",
    "        'cv':       nz.std() / nz.mean() if len(nz) > 0 and nz.mean() > 0 else 0,\n",
    "        'total':    y.sum(),\n",
    "        'tip':      classify_sku(y)\n",
    "    })\n",
    "\n",
    "sdf = pd.DataFrame(sku_stats)\n",
    "\n",
    "print('=== SKU TİP DAĞILIMI ===')\n",
    "print(sdf['tip'].value_counts().to_string())\n",
    "print()\n",
    "print('=== KATEGORİ x TİP ===')\n",
    "print(pd.crosstab(sdf['cat'], sdf['tip']).to_string())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# SKU tip pasta\n",
    "tip_counts = sdf['tip'].value_counts()\n",
    "colors = ['#ef4444','#f97316','#eab308','#22c55e','#3b82f6']\n",
    "axes[0].pie(tip_counts.values, labels=tip_counts.index, autopct='%1.0f%%',\n",
    "            colors=colors[:len(tip_counts)], startangle=90)\n",
    "axes[0].set_title('SKU Tip Dağılımı (n=360)', fontweight='bold')\n",
    "\n",
    "# Kategori çubuk\n",
    "cat_tip = pd.crosstab(sdf['cat'], sdf['tip'])\n",
    "cat_tip.plot(kind='bar', ax=axes[1], color=colors[:len(cat_tip.columns)], edgecolor='white')\n",
    "axes[1].set_title('Kategori x Tip', fontweight='bold')\n",
    "axes[1].set_xlabel('')\n",
    "axes[1].tick_params(axis='x', rotation=20)\n",
    "axes[1].legend(fontsize=8)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. ABC Analizi"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "sku_total = sdf.sort_values('total', ascending=False).reset_index(drop=True)\n",
    "sku_total['cum_pct'] = sku_total['total'].cumsum() / sku_total['total'].sum()\n",
    "sku_total['abc'] = pd.cut(sku_total['cum_pct'], bins=[0, 0.80, 0.95, 1.0], labels=['A','B','C'])\n",
    "\n",
    "sdf = sdf.merge(sku_total[['sku','abc']], on='sku', how='left')\n",
    "\n",
    "print('=== ABC ANALİZİ ===')\n",
    "abc_sum = sku_total.groupby('abc', observed=True).agg(sku_sayisi=('sku','count'), toplam_satis=('total','sum'))\n",
    "abc_sum['satis_pct'] = abc_sum['toplam_satis'] / abc_sum['toplam_satis'].sum() * 100\n",
    "print(abc_sum.to_string())\n",
    "print()\n",
    "print('=== TOP 10 SKU ===')\n",
    "top10 = sku_total.head(10).merge(attr[['sku','ItDesc']], on='sku', how='left')\n",
    "for _, r in top10.iterrows():\n",
    "    print(f'  {r[\"sku\"]:<22} {r[\"total\"]:>10,.0f}  [{r[\"abc\"]}]  {str(r[\"ItDesc\"])[:40]}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Lorenz curve\n",
    "axes[0].plot(np.arange(1, len(sku_total)+1) / len(sku_total) * 100,\n",
    "             sku_total['cum_pct'] * 100, color='#3b82f6', linewidth=2)\n",
    "axes[0].plot([0, 100], [0, 100], 'k--', alpha=0.4, label='Eşit dağılım')\n",
    "axes[0].axhline(80, color='#ef4444', linestyle=':', alpha=0.7, label='%80 satış')\n",
    "axes[0].axvline(len(sku_total[sku_total['abc']=='A'])/len(sku_total)*100,\n",
    "                color='#ef4444', linestyle=':', alpha=0.7)\n",
    "axes[0].set_xlabel('SKU (%)'); axes[0].set_ylabel('Kümülatif Satış (%)')\n",
    "axes[0].set_title('Lorenz Eğrisi — ABC', fontweight='bold')\n",
    "axes[0].legend(); axes[0].grid(alpha=0.3)\n",
    "\n",
    "# ABC pasta\n",
    "abc_counts = sku_total['abc'].value_counts().sort_index()\n",
    "axes[1].pie(abc_counts.values, labels=[f'Sınıf {l}\\n({n} SKU)' for l, n in abc_counts.items()],\n",
    "            autopct='%1.0f%%', colors=['#ef4444','#f97316','#6b7280'], startangle=90)\n",
    "axes[1].set_title('ABC Sınıf Dağılımı', fontweight='bold')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Mevsimsellik"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(1, 3, figsize=(16, 5))\n",
    "cats = ['MOTUL MOTOSİKLET', 'BS BATTERY', 'AUVRAY']\n",
    "colors_cat = ['#3b82f6', '#22c55e', '#f97316']\n",
    "ay_isimleri = ['Oca','Şub','Mar','Nis','May','Haz','Tem','Ağu','Eyl','Eki','Kas','Ara']\n",
    "\n",
    "for ax, cat, col in zip(axes, cats, colors_cat):\n",
    "    sub = panel[panel['ItAttrDesc'] == cat]\n",
    "    monthly = sub.groupby(sub['ds'].dt.month)['y'].mean()\n",
    "    baseline = monthly.mean()\n",
    "    index = monthly / baseline\n",
    "    bars = ax.bar(ay_isimleri, index.values, color=col, alpha=0.8, edgecolor='white')\n",
    "    ax.axhline(1.0, color='black', linestyle='--', linewidth=1, alpha=0.5)\n",
    "    ax.set_title(cat, fontweight='bold', fontsize=10)\n",
    "    ax.set_ylabel('Sezonalite İndeksi')\n",
    "    ax.tick_params(axis='x', rotation=45)\n",
    "    for bar, val in zip(bars, index.values):\n",
    "        ax.text(bar.get_x() + bar.get_width()/2, val + 0.02, f'{val:.2f}',\n",
    "                ha='center', va='bottom', fontsize=7)\n",
    "\n",
    "plt.suptitle('Kategori Bazında Mevsimsellik İndeksi', fontweight='bold', y=1.02)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Trend Analizi"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "trends = []\n",
    "for sku, grp in panel.groupby('sku'):\n",
    "    last = grp[grp['ds'] >= '2024-11-01']['y'].sum()\n",
    "    prev = grp[(grp['ds'] >= '2023-11-01') & (grp['ds'] < '2024-11-01')]['y'].sum()\n",
    "    if prev > 0:\n",
    "        trends.append({'sku': sku, 'prev': prev, 'last': last, 'pct': (last - prev) / prev * 100})\n",
    "    else:\n",
    "        trends.append({'sku': sku, 'prev': prev, 'last': last, 'pct': 0.0})\n",
    "\n",
    "tdf = pd.DataFrame(trends)\n",
    "print('=== TREND ÖZETI (son 12 ay vs önceki 12 ay) ===')\n",
    "print(f'  Büyüyen   (>+20%): {(tdf[\"pct\"] >  20).sum()} SKU')\n",
    "print(f'  Stabil (-20%~+20%): {((tdf[\"pct\"]>=-20) & (tdf[\"pct\"]<=20)).sum()} SKU')\n",
    "print(f'  Küçülen   (<-20%): {(tdf[\"pct\"] < -20).sum()} SKU')\n",
    "print(f'  Ölmüş  (son12=0): {(tdf[\"last\"] ==  0).sum()} SKU')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Trend histogram\n",
    "clipped = tdf['pct'].clip(-200, 200)\n",
    "axes[0].hist(clipped, bins=40, color='#3b82f6', edgecolor='white', alpha=0.8)\n",
    "axes[0].axvline(0,   color='black', linestyle='--', linewidth=1.5)\n",
    "axes[0].axvline(20,  color='#22c55e', linestyle=':', linewidth=1.5, label='+20%')\n",
    "axes[0].axvline(-20, color='#ef4444', linestyle=':', linewidth=1.5, label='-20%')\n",
    "axes[0].set_xlabel('Büyüme (%, -200/+200 arasında kırpılmış)')\n",
    "axes[0].set_ylabel('SKU Sayısı')\n",
    "axes[0].set_title('SKU Trend Dağılımı', fontweight='bold')\n",
    "axes[0].legend()\n",
    "\n",
    "# Aylık toplam satış trendi\n",
    "monthly_total = panel.groupby('ds')['y'].sum()\n",
    "axes[1].plot(monthly_total.index, monthly_total.values, color='#3b82f6', linewidth=2)\n",
    "axes[1].fill_between(monthly_total.index, monthly_total.values, alpha=0.15, color='#3b82f6')\n",
    "axes[1].set_title('Toplam Aylık Satış Trendi', fontweight='bold')\n",
    "axes[1].set_ylabel('Toplam Satış')\n",
    "axes[1].yaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'{x/1000:.0f}K'))\n",
    "axes[1].grid(alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Veri Kalitesi Sorunları"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('=== BUG: combineFİles.py tarih parsing ===')\n",
    "print('orders_raw ve stock_raw MonthStart formatı: GG-AA-YY (01-02-20 = 1 Şubat 2020)')\n",
    "print('pd.to_datetime() dayfirst=True olmadan: 01-02-20 → Ocak 2, 2020 (YANLIŞ)')\n",
    "print('Join tamamen başarısız → panel\\'de orders=%97 sıfır, stock=%95 sıfır')\n",
    "print()\n",
    "print('FIX (v1_processing.ipynb):')\n",
    "print('  orders[\"MonthStart\"] = pd.to_datetime(orders[\"MonthStart\"], dayfirst=True)')\n",
    "print('  stock[\"MonthStart\"]  = pd.to_datetime(stock[\"MonthStart\"],  dayfirst=True)')\n",
    "print()\n",
    "print('=== NEGATİF STOK ===')\n",
    "neg = panel[panel['stock'] < 0]\n",
    "print(f'Toplam: {len(neg)} satır, {neg[\"sku\"].nunique()} SKU')\n",
    "print(f'Min: {panel[\"stock\"].min():.0f}')\n",
    "print('Sebep: ERP iade/düzeltme kayıtları')\n",
    "print('FIX: stock = max(0, stock)')\n",
    "print()\n",
    "print('=== ÖLMÜŞ SKU ===')\n",
    "dead = panel.groupby('sku').apply(lambda g: (g['ds'] >= '2024-11-01') & (g['y'] > 0)).any(level=0) if False else \\\n",
    "       panel.groupby('sku').filter(lambda g: g[g['ds'] >= '2024-11-01']['y'].sum() == 0)['sku'].unique()\n",
    "print(f'{len(dead)} SKU son 12 ayda hiç satış yapmamış → sıfır tahmin verilmeli')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Model Kararları Özeti"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "summary = {\n",
    "    'Bulgu': [\n",
    "        'combineFİles.py dayfirst bug',\n",
    "        'Negatif stok (175 SKU)',\n",
    "        '46 ölmüş SKU',\n",
    "        '160 ÖLMEKTE SKU (>%70 sıfır)',\n",
    "        '9 A-sınıfı SKU = %80 satış',\n",
    "        'BS Battery 1.71x sezonalite',\n",
    "    ],\n",
    "    'Model Etkisi': [\n",
    "        'orders/stock feature panele düzgün geliyor → FIX sonrası kullanılabilir',\n",
    "        'stock feature bozuk → max(0, stock) clip',\n",
    "        'Sıfır tahmin ver, pipeline\\'a dahil etme',\n",
    "        'TSB override threshold %50 yeterli',\n",
    "        'Escalation (Prophet+XGB) A-sınıfına zorla',\n",
    "        'sin/cos ay encoding ekle',\n",
    "    ]\n",
    "}\n",
    "\n",
    "smdf = pd.DataFrame(summary)\n",
    "print('=== MODEL KARARLARI ===')\n",
    "for _, r in smdf.iterrows():\n",
    "    print(f'  [{r[\"Bulgu\"]}]')\n",
    "    print(f'    → {r[\"Model Etkisi\"]}')\n",
    "    print()\n",
    "\n",
    "print('Sonraki adım: notebooks/v1_processing.ipynb')"
   ]
  }
