# Rust controller base URL (dashboard bu URL'e ba\u011flan\u0131r)
VITE_API_BASE_URL=http://localhost:9000

# Grafana embed URL (analiz sayfas\u0131 iframe'i)
VITE_GRAFANA_URL=http://localhost:3000

# Statik pipeline_results.json modunu etkinle\u015ftir (backend yerine JSON dosyas\u0131 kullan)
VITE_USE_STATIC_SOURCE=false

# MSW mock mode (geli\u015ftirme s\u0131ras\u0131nda backend olmadan \u00e7al\u0131\u015ft\u0131rma)
VITE_USE_MSW=false
